{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "alice-live://schemas/clipmaker-quality-annotations/v1",
  "title": "Clipmaker quality annotations",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "review_ticket",
    "dataset",
    "session_started_at",
    "exported_at",
    "summary",
    "annotations",
    "drafts"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "artifact_kind": { "const": "clipmaker-quality-annotations" },
    "review_ticket": { "const": "PROMOPAGES-9897" },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source_ticket",
        "batch_id",
        "manifest_path",
        "manifest_sha256",
        "data_sha256"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "source_ticket": { "type": ["string", "null"] },
        "batch_id": { "type": "string", "minLength": 1 },
        "manifest_path": { "type": "string", "minLength": 1 },
        "manifest_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "data_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "session_started_at": { "type": "string", "format": "date-time" },
    "exported_at": { "type": "string", "format": "date-time" },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "completed", "drafts"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "completed": { "type": "integer", "minimum": 0 },
        "drafts": { "type": "integer", "minimum": 0 }
      }
    },
    "annotations": {
      "type": "array",
      "items": { "$ref": "#/$defs/completedAnnotation" }
    },
    "drafts": {
      "type": "array",
      "items": { "$ref": "#/$defs/draftAnnotation" }
    }
  },
  "$defs": {
    "baseAnnotation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "annotation_id",
        "item_id",
        "video",
        "context_snapshot",
        "prompt_snapshot",
        "rating",
        "feedback",
        "agent_id",
        "model_id",
        "run_id",
        "batch_id",
        "author_thread_id",
        "generation_job_id",
        "request_sha256",
        "provider_contract",
        "updated_at"
      ],
      "properties": {
        "annotation_id": { "type": "string", "minLength": 1 },
        "item_id": { "type": "string", "minLength": 1 },
        "video": { "$ref": "#/$defs/video" },
        "context_snapshot": { "type": "object" },
        "prompt_snapshot": { "type": "object" },
        "rating": { "type": ["integer", "null"], "enum": [1, 2, 3, null] },
        "feedback": { "type": "string" },
        "agent_id": { "type": "string", "minLength": 1 },
        "model_id": { "type": "string", "minLength": 1 },
        "run_id": { "type": "string", "minLength": 1 },
        "batch_id": { "type": "string", "minLength": 1 },
        "author_thread_id": { "type": "string", "minLength": 1 },
        "generation_job_id": { "type": "string", "minLength": 1 },
        "request_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "provider_contract": { "type": "object" },
        "completed_at": { "type": ["string", "null"], "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "completedAnnotation": {
      "allOf": [
        { "$ref": "#/$defs/baseAnnotation" },
        {
          "type": "object",
          "required": ["completed_at"],
          "properties": {
            "rating": { "type": "integer", "enum": [1, 2, 3] },
            "completed_at": { "type": "string", "format": "date-time" }
          },
          "if": {
            "properties": { "rating": { "enum": [1, 2] } },
            "required": ["rating"]
          },
          "then": {
            "properties": { "feedback": { "type": "string", "pattern": "\\S" } },
            "required": ["feedback"]
          }
        }
      ]
    },
    "draftAnnotation": {
      "allOf": [
        { "$ref": "#/$defs/baseAnnotation" },
        {
          "type": "object",
          "required": ["completed_at"],
          "properties": {
            "completed_at": { "type": "null" }
          }
        }
      ]
    },
    "video": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "sha256"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  }
}
